{
  "name": "mi-distrito",
  "version": "0.1.0",
  "description": "Plataforma cívica multi-distrito para el Perú",
  "private": true,
  "scripts": {
    "build": "pnpm run typecheck && pnpm -r --if-present run build",
    "dev:api": "pnpm --filter @midistrito/api run dev",
    "dev:web": "pnpm --filter @midistrito/web run dev",
    "typecheck": "tsc --build",
    "test": "pnpm -r --if-present run test"
  },
  "devDependencies": {
    "prettier": "^3.8.1",
    "typescript": "~5.9.2"
  },
  "engines": {
    "node": ">=20"
  }
}
