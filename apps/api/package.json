{
  "name": "@midistrito/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch ./src/index.ts",
    "build": "tsc -p tsconfig.json --noEmit",
    "start": "tsx ./src/index.ts",
    "migrate": "cd ../../lib/db && drizzle-kit migrate --config ./drizzle.config.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@midistrito/api-zod": "workspace:*",
    "@midistrito/core": "workspace:*",
    "@midistrito/db": "workspace:*",
    "bcryptjs": "^3.0.2",
    "cheerio": "^1.0.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "drizzle-zod": "^0.8.3",
    "express": "^5",
    "express-rate-limit": "^7.5.0",
    "helmet": "^9.0.0",
    "jsonwebtoken": "^9.0.2",
    "node-cron": "^3.0.3",
    "pino": "^9.6.0",
    "pino-http": "^10.5.0",
    "rss-parser": "^3.13.0",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/cookie-parser": "^1.4.8",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "catalog:",
    "@types/supertest": "^7.2.0",
    "pino-pretty": "^13",
    "supertest": "^7.2.2",
    "tsx": "catalog:",
    "typescript": "~5.9.2",
    "vitest": "^3.1.3"
  }
}
