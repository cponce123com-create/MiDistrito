# ── Base de Datos ───────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@ep-example-123456.us-east-2.aws.neon.tech/midistrito?sslmode=require

# ── Autenticación ──────────────────────────────────────────────────────────
JWT_SECRET=your-jwt-secret-here
LICENSE_SECRET=your-license-secret-here

# ── Servidor ───────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── CORS ───────────────────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:5173,http://localhost:3000

# ── Super Admin ────────────────────────────────────────────────────────────
SUPER_ADMIN_EMAIL=tu-email@ejemplo.com

# ── Cloudinary (imágenes) ──────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=tu-cloud-name
CLOUDINARY_API_KEY=tu-api-key
CLOUDINARY_API_SECRET=tu-api-secret

# ── Seed ───────────────────────────────────────────────────────────────────
SEED_KEY=my-secret-seed-key-2024

# ── App ────────────────────────────────────────────────────────────────────
APP_URL=http://localhost:5173
