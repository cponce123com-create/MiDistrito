# ── Base de Datos ───────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@ep-example-123456.us-east-2.aws.neon.tech/midistrito?sslmode=require

# ── Autenticación ──────────────────────────────────────────────────────────
JWT_SECRET=your-jwt-secret-here
LICENSE_SECRET=your-license-secret-here

# ── Servidor ───────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── CORS ───────────────────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:5173,http://localhost:3000

# ── Super Admin ────────────────────────────────────────────────────────────
SUPER_ADMIN_EMAIL=tu-email@ejemplo.com

# ── Cloudinary (imágenes) ──────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=tu-cloud-name
CLOUDINARY_API_KEY=tu-api-key
CLOUDINARY_API_SECRET=tu-api-secret

# ── Seed ───────────────────────────────────────────────────────────────────
SEED_KEY=my-secret-seed-key-2024

# ── App ────────────────────────────────────────────────────────────────────
APP_URL=http://localhost:5173

# ── Módulo News ─────────────────────────────────────────────────────────────
# Token del bot de Telegram para publicar noticias
TELEGRAM_BOT_TOKEN=tu-telegram-bot-token

# API ID y Hash para MTProto (leer canales Telegram vía GramJS)
# Obtener en https://my.telegram.org/apps
TELEGRAM_API_ID=tu-api-id
TELEGRAM_API_HASH=tu-api-hash

# Habilitar el scraper automático de noticias (true/false)
NEWS_SCRAPER_ENABLED=false

# Intervalo del scraper en minutos (default: 30)
NEWS_SCRAPER_INTERVAL=30
